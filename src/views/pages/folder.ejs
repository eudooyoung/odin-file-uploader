<main class="folder detail">
  <h2 class="header"><%= folder.name %></h2>
  <div class="info">
    <p>폴더 아이디: <%= folder.id %></p>
    <p>생성 날짜: <%= folder.createdAt %></p>
    <button type="button" command="show-modal" commandfor="upload-file-form">파일 추가</button>
    <dialog id="upload-file-form" closedby="any">
      <form action="/storage/folder/<%= folder.id %>/file/upload" method="post" enctype="multipart/form-data">
        <label for="files">파일을 선택하세요</label>
        <input type="file" name="files" id="files" multiple="true">
        <button type="submit">업로드</button>
        <button type="button" commandfor="create-folder-form" command="close">취소</button>
      </form>
    </dialog>
    <section>
      <h3>파일목록</h3>
    </section>
  </div>
  <%- include("../partials/folders") %>
</main>