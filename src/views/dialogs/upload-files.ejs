<dialog id="upload-file" closedby="any">
  <form action="/storage/folder/<%= folder.id %>/file/upload" method="post" enctype="multipart/form-data">
    <label for="files">파일을 선택하세요</label>
    <input type="file" name="files" id="files" multiple="true" required>
    <button type="submit">업로드</button>
    <button type="button" commandfor="upload-file" command="close">취소</button>
  </form>
</dialog>